rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Stripe orders are created and updated only by trusted Admin SDK functions.
    // Browser clients cannot read customer/payment data or mutate any order field.
    match /orders/{document=**} {
      allow read, write: if false;
    }

    // Preserve the existing public-read/client-write-deny policy everywhere else.
    // The collection check prevents this broader rule from overriding /orders.
    match /{collection}/{document=**} {
      allow read: if collection != "orders";
      allow write: if false;
    }
  }
}